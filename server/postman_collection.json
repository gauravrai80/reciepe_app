								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favorites",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favorites"
							]
						},
						"description": "Retrieves the logged-in user's favorite recipe IDs."
					},
					"response": []
				},
				{
					"name": "Add Favorite",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"recipeId\": \"12345\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/favorites",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favorites"
							]
						},
						"description": "Adds a recipe ID to the user's favorites."
					},
					"response": []
				},
				{
					"name": "Remove Favorite",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/favorites/:recipeId",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"favorites",
								":recipeId"
							],
							"variable": [
								{
									"key": "recipeId",
									"value": "12345",
									"description": "The ID of the recipe to remove"
								}
							]
						},
						"description": "Removes a recipe ID from the user's favorites."
					},
					"response": []
				}

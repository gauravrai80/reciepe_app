		{
			"name": "Recipes",
			"item": [
				{
					"name": "Create Recipe",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Spaghetti Bolognese\",\n    \"description\": \"A classic Italian pasta dish.\",\n    \"ingredients\": [\n        \"Spaghetti\",\n        \"Ground Beef\",\n        \"Tomato Sauce\",\n        \"Garlic\",\n        \"Onion\"\n    ],\n    \"instructions\": \"1. Boil pasta.\\n2. Brown the beef with onions and garlic.\\n3. Add tomato sauce and simmer.\\n4. Serve over pasta.\",\n    \"prepTime\": 45,\n    \"category\": \"Italian\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/recipes",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recipes"
							]
						},
						"description": "Creates a new recipe. Requires authentication."
					},
					"response": []
				},
				{
					"name": "Get All Recipes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/recipes",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recipes"
							]
						},
						"description": "Retrieves all recipes from the database."
					},
					"response": []
				},
				{
					"name": "Get Recipe by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/recipes/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recipes",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "REPLACE_WITH_RECIPE_ID",
									"description": "The ID of the recipe"
								}
							]
						},
						"description": "Retrieves a single recipe by its ID."
					},
					"response": []
				},
				{
					"name": "Update Recipe",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"prepTime\": 50,\n    \"category\": \"Pasta\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/recipes/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recipes",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "REPLACE_WITH_RECIPE_ID",
									"description": "The ID of the recipe"
								}
							]
						},
						"description": "Updates an existing recipe. User must be the owner. Requires authentication."
					},
					"response": []
				},
				{
					"name": "Delete Recipe",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/recipes/:id",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"recipes",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "REPLACE_WITH_RECIPE_ID",
									"description": "The ID of the recipe"
								}
							]
						},
						"description": "Deletes a recipe. User must be the owner. Requires authentication."
					},
					"response": []
				}
			]
		},
		{
			"name": "Favorites",
			"item": [
				{
